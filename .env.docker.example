# 3. NUNCA commite o arquivo .env.docker

# JWT Configuration for Docker
JWT_SECRET=your_jwt_secret_in_base64
JWT_EXPIRATION=86400000

# PostgreSQL Password for Docker
POSTGRES_PASSWORD=your_postgres_password_here
